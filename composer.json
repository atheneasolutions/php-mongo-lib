{
    "name": "athenea/mongo-lib",
    "description": "Mongo utilities for Athenea Solutions",
    "autoload": {
        "psr-4": {
            "Athenea\\MongoLib\\": "src/"
        },
        "files": [ "bson.php" ]
    },
    "autoload-dev": {
        "psr-4": {
            "Athenea\\MongoLib\\Tests\\": "tests/"
        },
        "files": ["tests/Model/TestModels.php"]
    },
    "authors": [
        {
            "name": "Lluc Bové",
            "email": "lluc.bove@atheneasolutions.com"
        }
    ],
    "require": {
        "mongodb/mongodb": "^1.0 || ^2.0",
        "phpdocumentor/reflection-docblock": "^5.3",
        "symfony/property-info":    "^5.0 || ^6.0 || ^7.0 || ^8.0",
        "symfony/property-access":  "^5.0 || ^6.0 || ^7.0 || ^8.0"
    },
    "require-dev": {
        "soyuka/stubs-mongodb": "^1.0",
        "phpunit/phpunit": "^10.0"
    }
}
